---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const badgeStyles: Record<string, string> = {
  rose: 'bg-rose-500 text-white',
  gold: 'bg-gold-500 text-white',
  green: 'bg-emerald-500 text-white',
};

const discount = product.originalPrice
  ? Math.round((1 - product.price / product.originalPrice) * 100)
  : null;
---

<div class="card-product">
  <!-- Image Container -->
  <div class="relative overflow-hidden bg-gray-50 aspect-square">
    <img
      src={product.image}
      alt={product.name}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
      loading="lazy"
    />

    <!-- Overlay on hover -->
    <div class="absolute inset-0 bg-charcoal/0 group-hover:bg-charcoal/20 transition-all duration-500 flex items-center justify-center">
      <div class="flex gap-3 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-4 group-hover:translate-y-0">
        <button class="w-11 h-11 bg-white rounded-full shadow-lg flex items-center justify-center text-charcoal hover:text-gold-600 hover:scale-110 transition-all duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </button>
        <button class="w-11 h-11 bg-white rounded-full shadow-lg flex items-center justify-center text-charcoal hover:text-rose-500 hover:scale-110 transition-all duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Badge -->
    {product.badge && (
      <span class={`badge ${badgeStyles[product.badgeColor || 'gold']}`}>
        {product.badge}
        {discount && ` -${discount}%`}
      </span>
    )}

    <!-- Quick add button -->
    <div class="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-400">
      <button class="w-full py-3 bg-charcoal hover:bg-gold-600 text-white text-sm font-medium transition-colors duration-300 flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
        </svg>
        Adicionar ao Carrinho
      </button>
    </div>
  </div>

  <!-- Product Info -->
  <div class="p-5">
    <p class="text-xs text-gold-600 font-semibold uppercase tracking-wider mb-1">{product.material}</p>
    <h3 class="font-serif text-lg font-semibold text-charcoal group-hover:text-gold-700 transition-colors duration-200 leading-snug">
      {product.name}
    </h3>
    <p class="text-gray-400 text-sm mt-1 line-clamp-1">{product.description}</p>

    <div class="flex items-center justify-between mt-4">
      <div class="flex items-end gap-2">
        <span class="font-serif text-xl font-bold text-gold-700">
          R$ {product.price.toFixed(2).replace('.', ',')}
        </span>
        {product.originalPrice && (
          <span class="text-gray-400 text-sm line-through">
            R$ {product.originalPrice.toFixed(2).replace('.', ',')}
          </span>
        )}
      </div>
      <!-- Stars -->
      <div class="flex items-center gap-0.5">
        {[1,2,3,4,5].map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 text-gold-400">
            <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
          </svg>
        ))}
      </div>
    </div>
  </div>
</div>
