---
const cats = [
  {
    label: 'Colares',
    description: 'Do delicado ao marcante',
    image: 'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=500&q=80',
    color: 'from-amber-900/70',
    href: '#colecao',
  },
  {
    label: 'Pulseiras',
    description: 'Elegância no pulso',
    image: 'https://images.unsplash.com/photo-1603974372039-adc49044b6bd?w=500&q=80',
    color: 'from-rose-900/70',
    href: '#colecao',
  },
  {
    label: 'Brincos',
    description: 'Brilho a cada detalhe',
    image: 'https://images.unsplash.com/photo-1610694955371-d4a3e0ce4b52?w=500&q=80',
    color: 'from-yellow-900/70',
    href: '#colecao',
  },
  {
    label: 'Anéis',
    description: 'Símbolo de sofisticação',
    image: 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=500&q=80',
    color: 'from-purple-900/70',
    href: '#colecao',
  },
  {
    label: 'Conjuntos',
    description: 'Harmonia completa',
    image: 'https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=500&q=80',
    color: 'from-teal-900/70',
    href: '#colecao',
  },
];
---

<section id="categorias" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-gold-600 text-sm font-semibold uppercase tracking-[0.2em]">Explore</span>
      <h2 class="section-title mt-2">Categorias</h2>
      <div class="divider-gold"></div>
      <p class="section-subtitle max-w-lg mx-auto">
        Encontre a peça perfeita para cada ocasião em nossa coleção curada.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {cats.map((cat, i) => (
        <a
          href={cat.href}
          class="relative group rounded-2xl overflow-hidden aspect-[3/4] cursor-pointer shine-effect"
          style={`animation-delay: ${i * 0.1}s`}
        >
          <img
            src={cat.image}
            alt={cat.label}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            loading="lazy"
          />
          <div class={`absolute inset-0 bg-gradient-to-t ${cat.color} to-transparent flex flex-col justify-end p-5`}>
            <h3 class="font-serif text-white text-xl font-bold">{cat.label}</h3>
            <p class="text-white/70 text-xs mt-1 group-hover:text-white/100 transition-colors duration-200">{cat.description}</p>
            <div class="flex items-center gap-1 mt-3 text-gold-300 text-xs font-medium group-hover:gap-2 transition-all duration-300">
              <span>Ver peças</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
