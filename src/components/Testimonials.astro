---
import { testimonials } from '../data/products';
---

<section class="py-24 bg-cream overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-gold-600 text-sm font-semibold uppercase tracking-[0.2em]">Depoimentos</span>
      <h2 class="section-title mt-2">O que dizem nossas clientes</h2>
      <div class="divider-gold"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <div
          class="bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl transition-all duration-500 relative group border border-gray-100 hover:border-gold-200"
          style={`animation-delay: ${i * 0.15}s`}
        >
          <!-- Quote icon -->
          <div class="absolute top-6 right-8 text-gold-200 group-hover:text-gold-300 transition-colors duration-300">
            <svg width="40" height="32" viewBox="0 0 40 32" fill="currentColor">
              <path d="M0 32V19.2C0 8.533 5.333 2.133 16 0l2.4 3.2C13.067 4.533 9.867 7.733 8.8 12.8H16V32H0zm24 0V19.2C24 8.533 29.333 2.133 40 0l2.4 3.2c-5.333 1.333-8.533 4.533-9.6 9.6H40V32H24z"/>
            </svg>
          </div>

          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-gold-400">
                <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
              </svg>
            ))}
          </div>

          <p class="text-gray-600 text-base leading-relaxed mb-6 italic">"{t.text}"</p>

          <div class="flex items-center gap-3">
            <div class="w-11 h-11 gold-gradient rounded-full flex items-center justify-center text-white font-bold text-sm shadow-md">
              {t.avatar}
            </div>
            <div>
              <p class="font-semibold text-charcoal text-sm">{t.name}</p>
              <p class="text-gray-400 text-xs">{t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap items-center justify-center gap-8 mt-16 pt-10 border-t border-gray-200">
      <div class="flex items-center gap-2 text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-gold-500">
          <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm font-medium">4.9/5 de avaliação média</span>
      </div>
      <div class="w-px h-5 bg-gray-300"></div>
      <div class="flex items-center gap-2 text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-gold-500">
          <path d="M4.5 6.375a4.125 4.125 0 118.25 0 4.125 4.125 0 01-8.25 0zM14.25 8.625a3.375 3.375 0 116.75 0 3.375 3.375 0 01-6.75 0zM1.5 19.125a7.125 7.125 0 0114.25 0v.003l-.001.119a.75.75 0 01-.363.63 13.067 13.067 0 01-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 01-.364-.63l-.001-.122zM17.25 19.128l-.001.144a2.25 2.25 0 01-.233.96 10.088 10.088 0 005.06-1.01.75.75 0 00.42-.643 4.875 4.875 0 00-6.957-4.611 8.586 8.586 0 011.71 5.157v.003z" />
        </svg>
        <span class="text-sm font-medium">+2.000 clientes satisfeitas</span>
      </div>
      <div class="w-px h-5 bg-gray-300"></div>
      <div class="flex items-center gap-2 text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-gold-500">
          <path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 00-1.032 0 11.209 11.209 0 01-7.877 3.08.75.75 0 00-.722.515A12.74 12.74 0 002.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 00.374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 00-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.734-3.08z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm font-medium">Compra 100% segura</span>
      </div>
    </div>
  </div>
</section>
