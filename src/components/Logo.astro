---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  dark?: boolean;
}
const { size = 'md', dark = false } = Astro.props;

const iconSize = size === 'sm' ? 30 : size === 'lg' ? 46 : 36;
const textClass = size === 'sm'
  ? 'text-xl'
  : size === 'lg'
  ? 'text-3xl'
  : 'text-2xl';
---

<a href="/" class="flex items-center gap-2.5 group select-none">
  <!-- Ícone Gema Dourada -->
  <svg
    width={iconSize}
    height={iconSize}
    viewBox="0 0 64 64"
    xmlns="http://www.w3.org/2000/svg"
    class="flex-shrink-0 group-hover:scale-110 transition-transform duration-400 drop-shadow-md"
  >
    <defs>
      <linearGradient id={`gem-top-${size}`} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#fde047"/>
        <stop offset="50%" stop-color="#d4af37"/>
        <stop offset="100%" stop-color="#92680a"/>
      </linearGradient>
      <linearGradient id={`gem-bot-${size}`} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#f5c842"/>
        <stop offset="100%" stop-color="#713f12"/>
      </linearGradient>
      <linearGradient id={`gem-shine-${size}`} x1="0%" y1="0%" x2="60%" y2="100%">
        <stop offset="0%" stop-color="#fffde7" stop-opacity="0.95"/>
        <stop offset="100%" stop-color="#fde047" stop-opacity="0"/>
      </linearGradient>
    </defs>

    <!-- Coroa da gema (topo) -->
    <polygon points="32,6 16,22 24,22 20,14 32,18 44,14 40,22 48,22" fill={`url(#gem-top-${size})`}/>

    <!-- Facetas do corpo -->
    <polygon points="16,22 32,58 10,36" fill={`url(#gem-bot-${size})`}/>
    <polygon points="48,22 32,58 54,36" fill={`url(#gem-bot-${size})`} opacity="0.85"/>
    <polygon points="16,22 32,22 10,36" fill={`url(#gem-top-${size})`} opacity="0.9"/>
    <polygon points="48,22 32,22 54,36" fill={`url(#gem-top-${size})`} opacity="0.75"/>
    <polygon points="16,22 48,22 32,38" fill={`url(#gem-top-${size})`} opacity="0.95"/>
    <polygon points="10,36 54,36 32,58" fill={`url(#gem-bot-${size})`} opacity="0.7"/>

    <!-- Brilho -->
    <polygon points="22,24 32,22 26,34" fill={`url(#gem-shine-${size})`} opacity="0.75"/>
    <ellipse cx="24" cy="26" rx="3" ry="2" fill="white" opacity="0.5" transform="rotate(-20,24,26)"/>
  </svg>

  <!-- Texto -->
  <div class="flex flex-col leading-none">
    <span class={`font-serif font-bold ${textClass} ${dark ? 'text-white' : 'text-charcoal'} tracking-tight`}>
      Mabê
    </span>
    <span class={`text-[10px] font-medium uppercase tracking-[0.18em] ${dark ? 'text-gold-300' : 'text-gold-600'} -mt-0.5`}>
      Semi-Joias
    </span>
  </div>
</a>
