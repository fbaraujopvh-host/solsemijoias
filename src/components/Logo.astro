---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  dark?: boolean;
}
const { size = 'md', dark = false } = Astro.props;

const iconSize = size === 'sm' ? 30 : size === 'lg' ? 46 : 36;
const textClass = size === 'sm'
  ? 'text-xl'
  : size === 'lg'
  ? 'text-3xl'
  : 'text-2xl';
---

<a href="/" class="flex items-center gap-2.5 group select-none">
  <!-- Ícone Rubi -->
  <svg
    width={iconSize}
    height={iconSize}
    viewBox="0 0 64 64"
    xmlns="http://www.w3.org/2000/svg"
    class="flex-shrink-0 group-hover:scale-110 transition-transform duration-400 drop-shadow-md"
  >
    <defs>
      <linearGradient id={`ruby-top-${size}`} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#ff6b8a"/>
        <stop offset="50%" stop-color="#c0392b"/>
        <stop offset="100%" stop-color="#7b0d1e"/>
      </linearGradient>
      <linearGradient id={`ruby-bot-${size}`} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#e84560"/>
        <stop offset="100%" stop-color="#5c0011"/>
      </linearGradient>
      <linearGradient id={`ruby-shine-${size}`} x1="0%" y1="0%" x2="60%" y2="100%">
        <stop offset="0%" stop-color="#ffb3c1" stop-opacity="0.9"/>
        <stop offset="100%" stop-color="#ff6b8a" stop-opacity="0"/>
      </linearGradient>
    </defs>

    <!-- Coroa do rubi (topo) -->
    <polygon points="32,6 16,22 24,22 20,14 32,18 44,14 40,22 48,22" fill={`url(#ruby-top-${size})`}/>

    <!-- Corpo do rubi (facetas) -->
    <!-- Faceta central esquerda -->
    <polygon points="16,22 32,58 10,36" fill={`url(#ruby-bot-${size})`}/>
    <!-- Faceta central direita -->
    <polygon points="48,22 32,58 54,36" fill={`url(#ruby-bot-${size})`} opacity="0.85"/>
    <!-- Faceta topo esquerda -->
    <polygon points="16,22 32,22 10,36" fill={`url(#ruby-top-${size})`} opacity="0.9"/>
    <!-- Faceta topo direita -->
    <polygon points="48,22 32,22 54,36" fill={`url(#ruby-top-${size})`} opacity="0.75"/>
    <!-- Faceta topo centro -->
    <polygon points="16,22 48,22 32,38" fill={`url(#ruby-top-${size})`} opacity="0.95"/>
    <!-- Fundo -->
    <polygon points="10,36 54,36 32,58" fill={`url(#ruby-bot-${size})`} opacity="0.7"/>

    <!-- Brilho -->
    <polygon points="22,24 32,22 26,34" fill={`url(#ruby-shine-${size})`} opacity="0.7"/>
    <ellipse cx="24" cy="26" rx="3" ry="2" fill="white" opacity="0.35" transform="rotate(-20,24,26)"/>
  </svg>

  <!-- Texto -->
  <div class="flex flex-col leading-none">
    <span class={`font-serif font-bold ${textClass} ${dark ? 'text-white' : 'text-charcoal'} tracking-tight`}>
      Mabê
    </span>
    <span class={`text-[10px] font-medium uppercase tracking-[0.18em] ${dark ? 'text-gold-300' : 'text-gold-600'} -mt-0.5`}>
      Semi-Joias
    </span>
  </div>
</a>
