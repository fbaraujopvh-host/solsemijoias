---
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-charcoal via-[#1a1a2e] to-[#16213e]">
  <!-- Background decorative elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full opacity-10"
      style="background: radial-gradient(circle, #d4af37, transparent 70%)"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full opacity-10"
      style="background: radial-gradient(circle, #b76e79, transparent 70%)"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full opacity-5"
      style="background: radial-gradient(circle, #d4af37, transparent 70%)"></div>
  </div>

  <!-- Floating decorative circles -->
  <div class="absolute top-20 left-10 w-3 h-3 rounded-full bg-gold-400 opacity-40 animate-float"></div>
  <div class="absolute top-40 right-20 w-2 h-2 rounded-full bg-gold-300 opacity-30 animate-float" style="animation-delay: 1s"></div>
  <div class="absolute bottom-40 left-20 w-4 h-4 rounded-full bg-gold-500 opacity-20 animate-float" style="animation-delay: 2s"></div>
  <div class="absolute top-60 left-1/3 w-2 h-2 rounded-full bg-rose-300 opacity-40 animate-float" style="animation-delay: 0.5s"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16 grid lg:grid-cols-2 gap-16 items-center">

    <!-- Text Content -->
    <div class="text-center lg:text-left animate-slide-up">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-gold-500/30 text-gold-300 text-sm font-medium px-4 py-2 rounded-full mb-6">
        <span class="w-2 h-2 bg-gold-400 rounded-full animate-pulse"></span>
        Nova Coleção 2026 Disponível
      </div>

      <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6">
        Elegância que
        <span class="block text-gold-gradient">brilha em você</span>
      </h1>

      <p class="text-gray-300 text-lg lg:text-xl leading-relaxed mb-10 max-w-lg mx-auto lg:mx-0 font-light">
        Semi-joias banhadas a ouro 18k e prata 925 com acabamento de joalheria premium.
        Peças únicas para momentos inesquecíveis.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <a href="#colecao" class="btn-primary text-base px-8 py-4 shine-effect">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
          Ver Coleção
        </a>
        <a href="#sobre" class="inline-flex items-center gap-2 text-white border border-white/30 hover:border-gold-400 hover:text-gold-400 font-medium px-8 py-4 rounded-full transition-all duration-300">
          Nossa História
        </a>
      </div>

      <!-- Stats -->
      <div class="flex items-center gap-8 mt-14 justify-center lg:justify-start">
        <div class="text-center">
          <p class="font-serif text-3xl font-bold text-gold-400">+2k</p>
          <p class="text-gray-400 text-sm mt-1">Clientes felizes</p>
        </div>
        <div class="w-px h-12 bg-white/20"></div>
        <div class="text-center">
          <p class="font-serif text-3xl font-bold text-gold-400">150+</p>
          <p class="text-gray-400 text-sm mt-1">Peças exclusivas</p>
        </div>
        <div class="w-px h-12 bg-white/20"></div>
        <div class="text-center">
          <p class="font-serif text-3xl font-bold text-gold-400">18k</p>
          <p class="text-gray-400 text-sm mt-1">Banho de ouro</p>
        </div>
      </div>
    </div>

    <!-- Hero Image Grid -->
    <div class="relative hidden lg:block animate-fade-in" style="animation-delay: 0.3s">
      <div class="grid grid-cols-2 gap-4">
        <!-- Main Image -->
        <div class="col-span-2 rounded-3xl overflow-hidden h-72 shine-effect shadow-2xl">
          <img
            src="https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=800&q=85"
            alt="Semi-joias elegantes"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
        <!-- Sub Images -->
        <div class="rounded-2xl overflow-hidden h-44 shine-effect shadow-xl">
          <img
            src="https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=400&q=85"
            alt="Colar banhado a ouro"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
        <div class="rounded-2xl overflow-hidden h-44 shine-effect shadow-xl">
          <img
            src="https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=400&q=85"
            alt="Conjunto de semi-joias"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
      </div>

      <!-- Floating badge -->
      <div class="absolute -top-4 -right-4 bg-white rounded-2xl shadow-xl p-4 animate-float">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 gold-gradient rounded-xl flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-5 h-5">
              <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 font-medium">Avaliação</p>
            <p class="font-serif text-lg font-bold text-charcoal">4.9 / 5.0</p>
          </div>
        </div>
      </div>

      <!-- Floating product card -->
      <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-xl p-4 animate-float" style="animation-delay: 1.5s">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl overflow-hidden">
            <img src="https://images.unsplash.com/photo-1603974372039-adc49044b6bd?w=100&q=80" alt="Pulseira" class="w-full h-full object-cover" />
          </div>
          <div>
            <p class="text-xs text-gray-500 font-medium">Mais Vendido</p>
            <p class="font-semibold text-charcoal text-sm">Pulseira Riviera</p>
            <p class="text-gold-600 font-bold text-sm">R$ 159,90</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/50 animate-bounce">
    <span class="text-xs font-medium tracking-widest uppercase">Rolar</span>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</section>
