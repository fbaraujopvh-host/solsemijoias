---
---

<section class="py-20 relative overflow-hidden" id="contato">
  <!-- Background -->
  <div class="absolute inset-0 gold-gradient opacity-95"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-black/20 to-transparent"></div>

  <!-- Decorative circles -->
  <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/5"></div>
  <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full bg-white/5"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-6 backdrop-blur-sm">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-8 h-8">
        <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
        <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
      </svg>
    </div>

    <h2 class="font-serif text-4xl md:text-5xl font-bold text-white mb-4">
      Receba novidades exclusivas
    </h2>
    <p class="text-white/80 text-lg mb-8 font-light">
      Cadastre-se e seja a primeira a saber sobre novas coleções, promoções especiais e cupons exclusivos.
    </p>

    <form class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" id="newsletter-form">
      <input
        type="email"
        placeholder="Seu melhor e-mail"
        required
        class="flex-1 px-5 py-4 rounded-full bg-white/95 backdrop-blur-sm text-charcoal placeholder-gray-400 outline-none focus:ring-2 focus:ring-white/50 text-sm font-medium shadow-lg"
      />
      <button
        type="submit"
        class="px-7 py-4 bg-charcoal hover:bg-charcoal/80 text-white font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 whitespace-nowrap text-sm"
      >
        Quero Receber!
      </button>
    </form>

    <p class="text-white/60 text-xs mt-4">
      Sem spam. Cancele quando quiser. 💛
    </p>

    <!-- Benefits -->
    <div class="flex flex-wrap items-center justify-center gap-6 mt-10">
      {['10% OFF na primeira compra', 'Lançamentos exclusivos', 'Ofertas antecipadas'].map(b => (
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-white">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
          </svg>
          {b}
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (btn) {
      btn.textContent = '✓ Cadastrado!';
      btn.disabled = true;
      btn.classList.add('bg-emerald-600');
    }
  });
</script>
